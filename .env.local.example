# ── Agora credentials (required) ─────────────────────────────────────────────
# Found in Agora Console → your project → App ID / App Certificate
NEXT_PUBLIC_AGORA_APP_ID=your_app_id_here
NEXT_AGORA_APP_CERTIFICATE=your_app_certificate_here

# ── Agent identity (optional) ─────────────────────────────────────────────────
# The RTC UID the AI agent joins with. Must not collide with real user UIDs.
NEXT_PUBLIC_AGENT_UID=123456

# ── Agora region (optional, defaults to US) ───────────────────────────────────
# Options: US | EU | AP | CN
AGORA_AREA=US

# ── Your company branding (optional) ─────────────────────────────────────────
COMPANY_NAME=Acme Corp
AGENT_NAME=Alex
AGENT_GREETING=Hi! I'm Alex, ready to help you with the docs. What would you like to know?

# ── Documentation source (choose ONE of the three options below) ──────────────

# Option 1 — Local folder of .md / .mdx files
DOCS_PATH=/path/to/your/docs/folder

# Option 2 — Remote llms.txt URL
# DOCS_LLM_URL=https://docs.yourcompany.com/llms.txt

# Option 3 — Inline static content
# DOCS_CONTENT="# My Product\n\nMy product does X, Y, and Z..."

# ── MCP doc retrieval (recommended for production) ────────────────────────────
#
# Set APP_URL to the publicly reachable base URL of your DocTalk deployment.
# Agora's cloud will call /api/mcp on every conversation turn to fetch only
# the documentation chunks relevant to the user's question (~2K tokens per turn
# instead of loading the entire corpus at session start).
#
# Without APP_URL, DocTalk still works but the agent won't have doc context.
# Use an ngrok tunnel for local testing: ngrok http 3000
#
APP_URL=https://your-doctalk.vercel.app

# Secret appended as ?key= on the MCP endpoint URL so only Agora can call search_docs.
# Generate one: openssl rand -hex 32
MCP_SECRET=replace-with-a-long-random-secret

# ── Security (optional but recommended for production) ───────────────────────
# Bearer token required on /api/invite-agent. Set to prevent arbitrary callers
# from creating agents on your Agora account.
# INVITE_SECRET=replace-with-a-long-random-secret

# Bearer token required on /api/reindex. Set if you expose the reindex endpoint.
# REINDEX_SECRET=replace-with-a-long-random-secret

# ── Voice tuning (optional) ───────────────────────────────────────────────────
# Deepgram language code — default: en. See https://developers.deepgram.com/docs/languages
# DOCS_LANGUAGE=en

# VAD interruption tuning — adjust for different languages / speaking styles
# VAD_SPEECH_THRESHOLD=0.5   # 0.0–1.0, higher = less sensitive
# VAD_INTERRUPT_MS=160       # ms of speech before interruption is triggered
# VAD_SILENCE_MS=480         # ms of silence before agent considers turn done

# ── Doc link display (optional) ───────────────────────────────────────────────
# When set, the transcript shows clickable "Related pages" links after
# each agent answer. DOCS_URL_LOCALE defaults to "en".
# DOCS_BASE_URL=https://docs.yourcompany.com
# DOCS_URL_LOCALE=en
